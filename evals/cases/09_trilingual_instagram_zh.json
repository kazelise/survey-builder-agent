{
  "name": "trilingual_instagram_zh",
  "category": "multi_step",
  "lang": "zh",
  "instruction": "建一个中文、日文、韩文三语问卷，风格用 Instagram，加一个帖子和一个单选题（选项：喜欢/不喜欢/中立），发布。",
  "mock_script": [
    {"tool_use": [{"name": "create_survey", "input": {
      "title": "三语态度调研", "platform_style": "instagram", "platform_ui_style": "instagram",
      "default_language": "zh-CN", "supported_languages": ["zh-CN", "ja", "ko"]
    }}]},
    {"tool_use": [{"name": "add_post", "input": {"survey_id": "$survey_id", "original_url": "https://instagram.com/p/1", "order": 1}}]},
    {"tool_use": [{"name": "add_post_question", "input": {
      "survey_id": "$survey_id", "post_id": "$post_ids[-1]", "question_type": "single_choice",
      "text": "你的态度是？", "order": 1, "config": {"options": ["喜欢", "不喜欢", "中立"]}
    }}]},
    {"tool_use": [{"name": "publish_survey", "input": {"survey_id": "$survey_id"}}]},
    {"tool_use": [{"name": "get_share_link", "input": {"survey_id": "$survey_id"}}]},
    {"final": "已发布，链接：{share_link}"}
  ],
  "expected_sequence": ["create_survey", "add_post", "add_post_question", "publish_survey"],
  "terminal_assert": {
    "status": "published",
    "supported_languages_exact": ["zh-CN", "ja", "ko"],
    "has_question_type": "single_choice",
    "post_count": 1
  }
}
