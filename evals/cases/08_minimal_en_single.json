{
  "name": "minimal_en_single",
  "category": "multi_step",
  "lang": "en",
  "instruction": "Create a minimal English-only single-group survey, add one post with a rating question, and publish it.",
  "mock_script": [
    {"tool_use": [{"name": "create_survey", "input": {"title": "Minimal Rating Survey", "default_language": "en", "supported_languages": ["en"]}}]},
    {"tool_use": [{"name": "add_post", "input": {"survey_id": "$survey_id", "original_url": "https://example.com/stim", "order": 1}}]},
    {"tool_use": [{"name": "add_post_question", "input": {
      "survey_id": "$survey_id", "post_id": "$post_ids[-1]", "question_type": "rating", "text": "Rate this post 0-4.", "order": 1, "config": {"min": 0, "max": 4}
    }}]},
    {"tool_use": [{"name": "publish_survey", "input": {"survey_id": "$survey_id"}}]},
    {"tool_use": [{"name": "get_share_link", "input": {"survey_id": "$survey_id"}}]},
    {"final": "Published. Share link: {share_link}"}
  ],
  "expected_sequence": ["create_survey", "add_post", "add_post_question", "publish_survey"],
  "terminal_assert": {
    "status": "published",
    "num_groups": 1,
    "post_count": 1,
    "has_question_type": "rating",
    "final_text_contains_any": ["Published", "share"]
  }
}
