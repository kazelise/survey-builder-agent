{
  "name": "recover_422_likert_range_en",
  "category": "error_recovery",
  "lang": "en",
  "instruction": "Add a likert trust question and publish the survey.",
  "notes": "Script deliberately submits an invalid range (min 5, max 1) first, then corrects it after the ToolError.",
  "mock_script": [
    {"tool_use": [{"name": "create_survey", "input": {"title": "Trust study", "default_language": "en", "supported_languages": ["en"]}}]},
    {"tool_use": [{"name": "add_post", "input": {"survey_id": "$survey_id", "original_url": "https://example.com/trust", "order": 1}}]},
    {"tool_use": [{"name": "add_survey_question", "input": {
      "survey_id": "$survey_id", "question_type": "likert", "text": "How much do you trust this?", "order": 1, "config": {"min": 5, "max": 1}
    }}]},
    {"if_last_error": {"tool_use": [{"name": "add_survey_question", "input": {
      "survey_id": "$survey_id", "question_type": "likert", "text": "How much do you trust this?", "order": 1, "config": {"min": 1, "max": 5}
    }}]}, "else": {"tool_use": [{"name": "publish_survey", "input": {"survey_id": "$survey_id"}}]}},
    {"tool_use": [{"name": "publish_survey", "input": {"survey_id": "$survey_id"}}]},
    {"tool_use": [{"name": "get_share_link", "input": {"survey_id": "$survey_id"}}]},
    {"final": "Published. Link: {share_link}"}
  ],
  "expected_sequence": ["create_survey", "add_post", "add_survey_question", "add_survey_question", "publish_survey"],
  "terminal_assert": {
    "status": "published",
    "has_question_type": "likert",
    "expect_error_from": ["add_survey_question"]
  }
}
