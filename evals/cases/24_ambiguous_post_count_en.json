{
  "name": "ambiguous_post_count_en",
  "category": "ambiguous",
  "lang": "en",
  "instruction": "I want a survey with a few stimulus posts and some questions, English only, then publish.",
  "notes": "'a few posts' is not a precise count — terminal_assert uses post_count_min instead of an exact number.",
  "mock_script": [
    {"tool_use": [{"name": "create_survey", "input": {"title": "A few posts study", "default_language": "en", "supported_languages": ["en"]}}]},
    {"tool_use": [{"name": "add_post", "input": {"survey_id": "$survey_id", "original_url": "https://example.com/few1", "order": 1}}]},
    {"tool_use": [{"name": "add_post", "input": {"survey_id": "$survey_id", "original_url": "https://example.com/few2", "order": 2}}]},
    {"tool_use": [{"name": "add_survey_question", "input": {
      "survey_id": "$survey_id", "question_type": "likert", "text": "Overall impression?", "order": 1, "config": {"min": 1, "max": 5}
    }}]},
    {"tool_use": [{"name": "publish_survey", "input": {"survey_id": "$survey_id"}}]},
    {"tool_use": [{"name": "get_share_link", "input": {"survey_id": "$survey_id"}}]},
    {"final": "Published with 2 posts. Link: {share_link}"}
  ],
  "expected_sequence": ["create_survey", "add_post", "add_post", "add_survey_question", "publish_survey"],
  "terminal_assert": {
    "status": "published",
    "post_count_min": 2
  }
}
