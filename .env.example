# Anthropic model client (optional — omit both and run with --mock instead)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
MODEL=claude-opus-4-8
# Model the loop switches to once, and stays on, after the primary model
# raises ModelUnavailableError (rate limit / 5xx / connection failure that
# survives SDK-level retries) -- see DESIGN.md §10.
MODEL_FALLBACK=claude-sonnet-5

# cs14 backend this agent talks to over HTTP (never imports backend/ code)
CS14_BASE_URL=http://localhost:8000/api/v1
CS14_EMAIL=cs14.demo@example.com
CS14_PASSWORD=change-me-client-demo
